<Page
    x:Class="MeowKey.Manager.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MeowKey.Manager.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="0,0,0,12">
            <Border Style="{StaticResource SectionCardStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="PageTitleText" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageDescriptionText"
                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button x:Name="RefreshInventoryButton"
                                Click="OnRefreshInventory" />
                        <Button x:Name="QueueProbePassButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="OnQueueProbePass" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{x:Bind Snapshot.Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DeviceEntry">
                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Bind Role}"
                                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{x:Bind FirmwareLabel}"
                                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind Firmware}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{x:Bind BoardLabel}"
                                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind Board}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="{x:Bind TransportLabel}"
                                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind Transport}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="{x:Bind State}"
                                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind Detail}" TextWrapping="WrapWholeWords" />
                                    <Button Content="{x:Bind SelectionLabel}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="0,6,0,0"
                                            Tag="{x:Bind DevicePath}"
                                            Click="OnSelectDevice" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="PoliciesTitleText" FontSize="18" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{x:Bind Snapshot.DevicePolicies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PolicyItem">
                                <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Title}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                        <TextBlock Text="{x:Bind Value}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Detail}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
