<Page
    x:Class="MeowKey.Manager.Pages.CredentialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MeowKey.Manager.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="0,0,0,12">
            <Border Style="{StaticResource SectionCardStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="PageTitleText" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageDescriptionText"
                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button x:Name="RefreshCatalogButton"
                                Click="OnRefreshCatalog" />
                        <Button x:Name="PlanSingleDeleteButton"
                                Click="OnPlanSingleDelete" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="CatalogTitleText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="CatalogDescriptionText"
                               Foreground="{ThemeResource AppMutedForegroundBrush}"
                               TextWrapping="WrapWholeWords" />

                    <ItemsControl ItemsSource="{x:Bind Snapshot.CredentialCatalogFacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:InfoItem">
                                <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Label}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                        <TextBlock Text="{x:Bind Value}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Detail}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border x:Name="CatalogGuidanceCard"
                    Style="{StaticResource SectionCardStyle}"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="CatalogGuidanceTitleText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="CatalogGuidanceDescriptionText"
                               Foreground="{ThemeResource AppMutedForegroundBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="CatalogGuidanceLine1Text" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="CatalogGuidanceLine2Text" TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="CatalogGuidanceLine3Text" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border x:Name="CatalogFiltersCard"
                    Style="{StaticResource SectionCardStyle}"
                    Visibility="Collapsed">
                <Grid ColumnSpacing="12" RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SearchLabelText"
                               Grid.Row="0"
                               Grid.Column="0"
                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                    <TextBlock x:Name="TypeFilterLabelText"
                               Grid.Row="0"
                               Grid.Column="1"
                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                    <TextBlock x:Name="HealthFilterLabelText"
                               Grid.Row="0"
                               Grid.Column="2"
                               Foreground="{ThemeResource AppMutedForegroundBrush}" />
                    <TextBlock x:Name="SortLabelText"
                               Grid.Row="0"
                               Grid.Column="3"
                               Foreground="{ThemeResource AppMutedForegroundBrush}" />

                    <TextBox x:Name="SearchTextBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             TextChanged="OnSearchTextChanged" />

                    <ComboBox x:Name="TypeFilterCombo"
                              Grid.Row="1"
                              Grid.Column="1"
                              SelectionChanged="OnCatalogFilterChanged">
                        <ComboBoxItem x:Name="TypeFilterAllItem" />
                        <ComboBoxItem x:Name="TypeFilterDiscoverableItem" />
                        <ComboBoxItem x:Name="TypeFilterServerSideItem" />
                    </ComboBox>

                    <ComboBox x:Name="HealthFilterCombo"
                              Grid.Row="1"
                              Grid.Column="2"
                              SelectionChanged="OnCatalogFilterChanged">
                        <ComboBoxItem x:Name="HealthFilterAllItem" />
                        <ComboBoxItem x:Name="HealthFilterReadyItem" />
                        <ComboBoxItem x:Name="HealthFilterMissingItem" />
                    </ComboBox>

                    <ComboBox x:Name="SortCombo"
                              Grid.Row="1"
                              Grid.Column="3"
                              SelectionChanged="OnCatalogFilterChanged">
                        <ComboBoxItem x:Name="SortSlotItem" />
                        <ComboBoxItem x:Name="SortSignCountItem" />
                        <ComboBoxItem x:Name="SortUserItem" />
                        <ComboBoxItem x:Name="SortRpItem" />
                    </ComboBox>
                </Grid>
            </Border>

            <Border x:Name="CatalogListCard"
                    Style="{StaticResource SectionCardStyle}"
                    Visibility="Collapsed">
                <ItemsControl ItemsSource="{x:Bind FilteredCatalog}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:CredentialCatalogItem">
                            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,8">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Subtitle}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                        <TextBlock Text="{x:Bind Detail}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind Footer}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OnShowCredentialDetails">
                                        <TextBlock Text="{x:Bind DetailsLabel}" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border x:Name="CatalogEmptyCard"
                    Style="{StaticResource SectionCardStyle}"
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CatalogEmptyTitleText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="CatalogEmptyDescriptionText"
                               Foreground="{ThemeResource AppMutedForegroundBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="CapabilityTitleText" FontSize="18" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{x:Bind Snapshot.CredentialCapabilities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CapabilityItem">
                                <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Name}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                        <TextBlock Text="{x:Bind Status}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Detail}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="EmptyStateTitleText" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="EmptyStateDescriptionText"
                               Foreground="{ThemeResource AppMutedForegroundBrush}"
                               TextWrapping="WrapWholeWords" />

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="EmptyStateNowTitleText" FontWeight="SemiBold" />
                            <TextBlock x:Name="EmptyStateLine1Text" />
                            <TextBlock x:Name="EmptyStateLine2Text" />
                            <TextBlock x:Name="EmptyStateLine3Text" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
