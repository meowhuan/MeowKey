<Page
    x:Class="MeowKey.Manager.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MeowKey.Manager.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Padding="0,0,0,12">
            <Border Style="{StaticResource SectionCardStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="PageTitleText" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageDescriptionText"
                                   Foreground="{ThemeResource AppMutedForegroundBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top">
                        <Button x:Name="RecordSnapshotButton"
                                Click="OnRecordSnapshot" />
                        <Button x:Name="PinLinuxNoteButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="OnPinLinuxNote" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}"
                    Background="{ThemeResource AppOutputBackgroundBrush}">
                <ListView ItemsSource="{x:Bind ActivityEntries}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ActivityEntry">
                            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,0,8">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{x:Bind TimestampText}"
                                                   Foreground="{ThemeResource AppMutedForegroundBrush}" />
                                        <TextBlock Text="{x:Bind Category}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Message}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
